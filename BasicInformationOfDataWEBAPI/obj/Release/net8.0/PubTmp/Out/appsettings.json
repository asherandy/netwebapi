{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // 允许的主机地址，"*"表示允许所有主机访问
  "AllowedHosts": "*",

  // JWT（JSON Web Token）配置部分
  "Jwt": {
    // JWT签名密钥，用于令牌的签名和验证
    "Key": "ThisIsASecretKeyForJwtSigning123456789",
    // 令牌签发者标识
    "Issuer": "localhost",
    // 令牌受众标识
    "Audience": "localhost",
    "ExpireMinutes": 60
  },

  // 数据库连接字符串(多数据源)
  "ConnectionStrings": {
    "axondb": "Server=192.168.1.119;Database=axondb;User Id=hmld;Password=sa123;TrustServerCertificate=True;",
    "BasicInformationOfData": "Server=rm-0xiep3munmaq533793o.sqlserver.rds.aliyuncs.com;Database=BasicInformationOfData;User Id=arthur;Password=Arthur@20241112;TrustServerCertificate=True;"
  },
  "Redis": {
    "RedisHost": "127.0.0.1:6379", // Redis 服务器地址和端口
    "RedisName": "BasicInformationAPI", // Redis Key 前缀，用于区分不同应用
    "Password": "", // Redis 密码， 非必填项
    "ConnectTimeoutSeconds": 5, // 连接超时时间（秒）
    "SessionExpireMinutes": 40 // redis 超时时间
  },
  

  "Kestrel": {
    "Endpoints": {
      "Http": {
       "Url": "http://localhost:5001"
      }
    }
  }



