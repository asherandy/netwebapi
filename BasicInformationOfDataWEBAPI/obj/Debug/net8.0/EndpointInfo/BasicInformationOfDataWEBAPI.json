{
  "openapi": "3.0.1",
  "info": {
    "title": "数据中台API",
    "description": "数据中台接口文档",
    "version": "v1"
  },
  "paths": {
    "/api/hello": {
      "get": {
        "tags": [
          "BasicInformationOfDataWEBAPI"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": [
          "Login"
        ],
        "summary": "登录",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/captchaImage": {
      "get": {
        "tags": [
          "Login"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/WeatherForecast/me": {
      "get": {
        "tags": [
          "WeatherForecast"
        ],
        "summary": "获取当前登录用户信息",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/WeatherForecast/Post": {
      "post": {
        "tags": [
          "WeatherForecast"
        ],
        "summary": "文件不能超过 5MB  ，只允许上传 jpg/png/pdf 文件",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "File"
                ],
                "type": "object",
                "properties": {
                  "File": {
                    "type": "string",
                    "description": "文件流",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "File": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名",
            "nullable": true
          },
          "password": {
            "type": "string",
            "description": "密码",
            "nullable": true
          },
          "uuid": {
            "type": "string",
            "description": "uuid",
            "nullable": true
          },
          "code": {
            "type": "string",
            "description": "验证",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "登录请求 DTO"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "使用 Bearer 方案的 JWT 授权标头。示例：\"Authorization: Bearer {token}\"",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ],
  "tags": [
    {
      "name": "WeatherForecast",
      "description": "默认"
    }
  ]
}