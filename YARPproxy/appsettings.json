{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
   


  "ReverseProxy": {
    "Routes": {
      "route1": {
        "ClusterId": "webapiCluster",
        "Match": { "Path": "{**catch-all}" }
      }
    },
    "Clusters": {
      "webapiCluster": {
        "Destinations": {
          "webapi1": { "Address": "http://localhost:5000" },
          "webapi2": { "Address": "http://localhost:5001" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:05", // 每 5 秒检查一次
            "Timeout": "00:00:05", // 检查超时时间 2 秒
            "Policy": "ConsecutiveFailures",
            "Path": "/health" // 请求这个路径检查健康
          }
        }
      }
    }

  }

}



